# ========== GLM Distill Platform Environment ==========

# PostgreSQL
POSTGRES_USER=distill
POSTGRES_PASSWORD=distill123
POSTGRES_DB=distill
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=models

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# GLM API (智谱开放平台)
# 申请地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4

# HuggingFace
HF_HOME=/data/hf_cache
HF_TOKEN=your_hf_token_here

# Model Paths (本地模型权重路径，可选)
TEACHER_MODEL_PATH=/data/models/glm-4-9b
STUDENT_MODEL_PATH=/data/models/chatglm3-6b

# Training Config
CUDA_VISIBLE_DEVICES=0,1,2,3
DEEPSPEED_CONFIG=configs/deepspeed_zero2.json
TRAIN_BATCH_SIZE=4
TRAIN_LEARNING_RATE=5e-5
TRAIN_EPOCHS=3

# Server
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
SECRET_KEY=your-secret-key-change-in-production
